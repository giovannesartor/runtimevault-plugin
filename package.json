{
  "name": "runtimevault-plugin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/commands/*.ts --format esm --outDir commands --clean && cp src/lib/types.ts commands/types.d.ts 2>/dev/null; echo done",
    "dev": "tsup src/commands/*.ts --format esm --outDir commands --watch",
    "prebuild": "rm -rf commands"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
